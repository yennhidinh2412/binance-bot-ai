# ============================================
# Bot AI Trading - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git!

# === Binance API Keys ===
# Testnet: https://testnet.binancefuture.com
# Production: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# === Mode ===
# true = Binance Testnet (paper trading)
# false = Binance Production (REAL money!)
BINANCE_TESTNET=true

# === Server ===
BOT_PORT=8080
FLASK_SECRET_KEY=change-this-to-random-string

# === Optional: Trusted IPs (comma-separated) ===
# TRUSTED_IPS=34.2.147.137,115.79.215.63
